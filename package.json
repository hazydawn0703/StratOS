{
  "name": "stratos-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -b --pretty false tsconfig.json",
    "build": "tsc -b tsconfig.json",
    "clean": "tsc -b --clean tsconfig.json",
    "test": "node --test tests/**/*.test.mjs tests/**/*.smoke.test.mjs",
    "finance:db:init": "node apps/finance/scripts/db-init.mjs",
    "finance:db:migrate": "node apps/finance/scripts/db-migrate.mjs",
    "finance:db:seed": "node apps/finance/scripts/db-seed.mjs",
    "finance:setup": "pnpm --filter @stratos/finance run setup",
    "finance:setup:bootstrap": "pnpm --filter @stratos/finance run setup:bootstrap",
    "finance:healthcheck": "pnpm --filter @stratos/finance run healthcheck",
    "finance:demo-run": "pnpm --filter @stratos/finance run demo-run",
    "finance:db:reset": "node apps/finance/scripts/db-reset.mjs",
    "finance:web:start": "FINANCE_WEB_AUTOSTART=1 node apps/finance/dist/web/FinanceWebRuntime.js"
  }
}
