{
  "name": "stratos-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -b --pretty false tsconfig.json",
    "build": "tsc -b tsconfig.json",
    "clean": "tsc -b --clean tsconfig.json",
    "test": "node --test tests/**/*.test.mjs tests/**/*.smoke.test.mjs"
  }
}
