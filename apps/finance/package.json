{
  "name": "@stratos/finance",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "node ./scripts/install.mjs",
    "dev": "FINANCE_WEB_AUTOSTART=1 node ./dist/web/FinanceWebRuntime.js",
    "test": "node --test ../../tests/finance-setup-*.test.mjs ../../tests/finance-setup-*.smoke.test.mjs",
    "typecheck": "tsc -b --pretty false",
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "db:init": "node ./scripts/db-init.mjs",
    "db:migrate": "node ./scripts/db-migrate.mjs",
    "db:seed": "node ./scripts/db-seed.mjs",
    "setup:bootstrap": "node ./scripts/setup-bootstrap.mjs",
    "setup:reset": "node ./scripts/setup-reset.mjs",
    "healthcheck": "node ./scripts/setup-healthcheck.mjs",
    "demo-run": "node ./scripts/setup-demo-run.mjs"
  },
  "dependencies": {
    "@stratos/core": "workspace:*",
    "@stratos/shared-types": "workspace:*",
    "@stratos/model-gateway": "workspace:*",
    "@stratos/stu-registry": "workspace:*",
    "@stratos/strategy-compiler": "workspace:*",
    "@stratos/rule-engine": "workspace:*",
    "@stratos/evaluation-engine": "workspace:*",
    "@stratos/experiment-engine": "workspace:*",
    "@stratos/bias-monitor": "workspace:*",
    "@stratos/ui": "workspace:*",
    "@stratos/claim-extractor": "workspace:*",
    "@stratos/review-engine": "workspace:*",
    "@stratos/error-utilization": "workspace:*",
    "@stratos/replay-debug": "workspace:*",
    "@stratos/model-router": "workspace:*"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
